rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ─────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (for username lookup on login)
    // Only the owner can write their own profile
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Progress subcollection — owner only
      match /progress/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Username reservation ──────────────────────────────────────────────────
    // Anyone can read (needed to check availability during signup)
    // Only authenticated users can reserve a username
    match /usernames/{username} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
